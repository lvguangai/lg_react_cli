{
  "name": "@lvguangai/react-cli",
  "description": "react + vite脚手架",
  "version": "1.0.0",
  "author": "lgzhoumingjie <zhoumingjie@lvguang.ai>",
  "license": "MIT",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "homepage": "https://github.com/lvguangai/lg_react_cli/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lvguangai/lg_react_cli.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "lg_react_cli",
    "vite",
    "react-cli",
    "@lvguangai/react-cli"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && vite build --mode production",
    "lint": "eslint . --fix --max-warnings 0",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/icons": "^6.3.2",
    "ahooks": "^3.9.7",
    "antd": "^6.5.0",
    "axios": "^1.18.1",
    "classnames": "^2.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "vite-plugin-svg-icons": "^2.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
